# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# PHP files
[*.php]
indent_style = space
indent_size = 4

# Blade files
[*.blade.php]
indent_style = space
indent_size = 4

# JavaScript files
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# CSS, SCSS, LESS files
[*.{css,scss,less}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Configuration files
[*.{xml,conf}]
indent_style = space
indent_size = 2

# Database files
[*.sql]
indent_style = space
indent_size = 2

# Composer files
[composer.json]
indent_style = space
indent_size = 4

# NPM files
[package.json]
indent_style = space
indent_size = 2

# Environment files
[.env*]
indent_style = space
indent_size = 2
