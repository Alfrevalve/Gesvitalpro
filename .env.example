APP_NAME=GesVitalPro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gesvitalpro
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@gesvitalpro.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sistema de Monitoreo
MONITORING_ENABLED=true
MONITORING_INTERVAL=300
MONITORING_CRITICAL_INTERVAL=60
MONITORING_CLEANUP_INTERVAL=86400
MONITORING_EMAIL_ALERTS=true
MONITORING_SLACK_ALERTS=false
MONITORING_SLACK_WEBHOOK=
MONITORING_SLACK_CHANNEL="#monitoring"
MONITORING_LOGGING_ENABLED=true
MONITORING_LOG_CHANNEL=monitoring
MONITORING_LOG_LEVEL=info

# Umbrales de Métricas
CPU_WARNING_THRESHOLD=80
CPU_CRITICAL_THRESHOLD=90
MEMORY_WARNING_THRESHOLD=85
MEMORY_CRITICAL_THRESHOLD=95
DISK_WARNING_THRESHOLD=85
DISK_CRITICAL_THRESHOLD=95
MYSQL_WARNING_THRESHOLD=80
MYSQL_CRITICAL_THRESHOLD=90
REDIS_WARNING_THRESHOLD=80
REDIS_CRITICAL_THRESHOLD=90
QUEUE_WARNING_THRESHOLD=100
QUEUE_CRITICAL_THRESHOLD=500

# Monitoreo de Rendimiento
PERFORMANCE_MONITORING_ENABLED=true
PERFORMANCE_SAMPLE_RATE=0.1
SLOW_REQUEST_THRESHOLD=1000
SLOW_QUERY_THRESHOLD=100
SLOW_REDIS_THRESHOLD=10

# Configuración del Dashboard
DASHBOARD_REFRESH_INTERVAL=30
DASHBOARD_CHART_POINTS=60
DASHBOARD_DEFAULT_VIEW=24h

# Verificaciones de Salud
HEALTH_CHECKS_ENABLED=true
HEALTH_CHECKS_SECRET=
HEALTH_CHECKS_TIMEOUT=5

# Monitoreo de Respaldos
BACKUP_MONITORING_ENABLED=true
BACKUP_THRESHOLD_DAYS=1
BACKUP_SIZE_THRESHOLD=104857600

# Retención de Datos
METRICS_RETENTION_DAYS=30

# PHP Settings
PHP_MEMORY_LIMIT=512M
MAX_EXECUTION_TIME=300
UPLOAD_MAX_FILESIZE=10M
POST_MAX_SIZE=10M

# Security Settings
SECURE_COOKIES=true
FORCE_HTTPS=false
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# Feature Flags
ENABLE_2FA=true
ENABLE_AUDIT_LOGS=true
ENABLE_API=true
ENABLE_NOTIFICATIONS=true
ENABLE_REPORTS=true

# Integrations
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cache Configuration
CACHE_PREFIX=gesvitalpro
CACHE_TTL=3600

# Queue Configuration
QUEUE_TIMEOUT=60
QUEUE_RETRY_AFTER=90
QUEUE_WORKER_SLEEP=3

# Debug Settings
DEBUGBAR_ENABLED=false
TELESCOPE_ENABLED=false
QUERY_DETECTOR_ENABLED=false
